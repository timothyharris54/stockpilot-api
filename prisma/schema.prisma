// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  active
  inactive
  archived
}

enum OrderStatus {
  pending
  authorized
  paid
  processing
  completed
  cancelled
  refunded
  partially_refunded
  on_hold
}

enum InventoryEventType {
  opening_balance
  sale
  sale_reversal
  receipt
  adjustment_gain
  adjustment_loss
  return_resellable
  sync_correction
}

enum ReferenceType {
  order
  receipt
  purchase_order
  adjustment
  return_ref
  system
}

model Account {
  id                      BigInt   @id @default(autoincrement())
  name                    String
  nextPurchaseOrderNumber Int      @default(1000)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                  User[]
  products               Product[]
  orders                 Order[]
  orderLines             OrderLine[]
  ledger                 InventoryLedger[]
  balances               InventoryBalance[]
  vendors                Vendor[]
  vendorProducts         VendorProduct[]
  purchaseOrders         PurchaseOrder[]
  purchaseOrderLines     PurchaseOrderLine[]
  receipts               Receipt[]
  receiptLines           ReceiptLine[]
  salesDaily             SalesDaily[]
  replenishmentRules     ReplenishmentRule[]
  reorderRecommendations ReorderRecommendation[]
  planningSettings       PlanningSettings?
}

model User {
  id        BigInt   @id @default(autoincrement())
  accountId BigInt
  email     String
  fullName  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
}

model Product {
  id              BigInt        @id @default(autoincrement())
  accountId       BigInt
  sku             String
  name            String
  status          ProductStatus @default(active)
  isVariant       Boolean       @default(false)
  parentProductId BigInt?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parentProduct Product?  @relation("ProductParent", fields: [parentProductId], references: [id])
  variants      Product[] @relation("ProductParent")

  orderLines             OrderLine[]
  ledgerEntries          InventoryLedger[]
  balances               InventoryBalance[]
  vendorProducts         VendorProduct[]
  purchaseOrderLines     PurchaseOrderLine[]
  receiptLines           ReceiptLine[]
  salesDaily             SalesDaily[]
  replenishmentRule      ReplenishmentRule?
  reorderRecommendations ReorderRecommendation[]

  @@unique([accountId, sku])

}

model Order {
  id             BigInt      @id @default(autoincrement())
  accountId      BigInt
  channel        String
  channelOrderId String
  status         OrderStatus
  orderedAt      DateTime
  customerName   String?
  customerEmail  String?
  currencyCode   String?
  orderTotal     Decimal?    @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderLines OrderLine[]

  @@unique([accountId, channel, channelOrderId])
}

model OrderLine {
  id            BigInt   @id @default(autoincrement())
  accountId     BigInt
  orderId       BigInt
  productId     BigInt?
  channelLineId String?
  sku           String?
  productName   String?
  quantity      Decimal  @db.Decimal(12, 2)
  unitPrice     Decimal? @db.Decimal(12, 2)
  lineTotal     Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model InventoryLedger {
  id               BigInt             @id @default(autoincrement())
  accountId        BigInt
  productId        BigInt
  locationCode     String
  eventType        InventoryEventType
  quantityDelta    Decimal            @db.Decimal(12, 2)
  unitCost         Decimal?           @db.Decimal(12, 4)
  referenceType    ReferenceType
  referenceId      BigInt?
  externalEventKey String
  occurredAt       DateTime
  notes            String?
  createdAt        DateTime           @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([accountId, externalEventKey])
}

model InventoryBalance {
  accountId        BigInt
  productId        BigInt
  locationCode     String
  qtyOnHand        Decimal  @default(0) @db.Decimal(12, 2)
  qtyReserved      Decimal  @default(0) @db.Decimal(12, 2)
  qtyIncoming      Decimal  @default(0) @db.Decimal(12, 2)
  qtyAvailable     Decimal  @default(0) @db.Decimal(12, 2)
  lastCalculatedAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId, locationCode])
}

enum PurchaseOrderStatus {
  draft
  submitted
  partially_received
  received
  cancelled
}

model Vendor {
  id                  BigInt   @id @default(autoincrement())
  accountId           BigInt
  name                String
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  defaultLeadTimeDays Int?
  paymentTerms        String?
  isActive            Boolean  @default(true)
  isPreferred         Boolean  @default(false)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  account                Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendorProducts         VendorProduct[]
  purchaseOrders         PurchaseOrder[]
  reorderRecommendations ReorderRecommendation[]

  @@unique([accountId, name])
}

model VendorProduct {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  vendorId        BigInt
  productId       BigInt
  vendorSku       String?
  unitCost        Decimal? @db.Decimal(12, 4)
  minOrderQty     Decimal  @default(0) @db.Decimal(12, 2)
  orderMultiple   Decimal  @default(1) @db.Decimal(12, 2)
  leadTimeDays    Int?
  isPrimaryVendor Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendor          Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  recommendations ReorderRecommendation[] @relation("RecommendationVendorProduct")

  purchaseOrderLines PurchaseOrderLine[]

  @@unique([accountId, vendorId, productId])
}

model PurchaseOrder {
  id          BigInt              @id @default(autoincrement())
  accountId   BigInt
  vendorId    BigInt
  poNumber    String
  locationCode String             @default("MAIN")
  status      PurchaseOrderStatus @default(draft)
  orderedAt   DateTime?
  expectedAt  DateTime?
  submittedAt DateTime?
  cancelledAt DateTime?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendor          Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines           PurchaseOrderLine[]
  receipts        Receipt[]
  recommendations ReorderRecommendation[] @relation("RecommendationPurchaseOrder")

  @@unique([accountId, poNumber])
}

model PurchaseOrderLine {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  purchaseOrderId BigInt
  productId       BigInt
  vendorProductId BigInt?
  orderedQty      Decimal  @db.Decimal(12, 2)
  receivedQty     Decimal  @default(0) @db.Decimal(12, 2)
  unitCost        Decimal? @db.Decimal(12, 4)
  lineTotal       Decimal? @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  vendorProduct   VendorProduct?          @relation(fields: [vendorProductId], references: [id], onDelete: SetNull)
  recommendations ReorderRecommendation[] @relation("RecommendationPurchaseOrderLine")
  receiptLines    ReceiptLine[]
}

model Receipt {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  purchaseOrderId BigInt
  locationCode    String
  receivedAt      DateTime
  notes           String?
  createdAt       DateTime @default(now())

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  lines         ReceiptLine[]
}

model ReceiptLine {
  id                  BigInt   @id @default(autoincrement())
  accountId           BigInt
  receiptId           BigInt
  purchaseOrderLineId BigInt
  productId           BigInt
  receivedQty         Decimal  @db.Decimal(12, 2)
  unitCost            Decimal? @db.Decimal(12, 4)
  createdAt           DateTime @default(now())

  account           Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  receipt           Receipt           @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
}

enum RecommendationStatus {
  open
  reviewed
  converted
  dismissed
  superseded
}

model SalesDaily {
  accountId BigInt
  productId BigInt
  salesDate DateTime
  unitsSold Decimal  @default(0) @db.Decimal(12, 2)
  revenue   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId, salesDate])
  @@index([accountId, salesDate])
  @@index([accountId, productId, salesDate])
}

model ReplenishmentRule {
  accountId    BigInt
  productId    BigInt @unique
  locationCode String @default("MAIN")

  safetyStock          Decimal @default(0) @db.Decimal(12, 2)
  targetDaysOfCover    Int     @default(30)
  overrideLeadTimeDays Int?
  minReorderQty        Decimal @default(0) @db.Decimal(12, 2)
  isActive             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId])
}

model ReorderRecommendation {
  id                  BigInt  @id @default(autoincrement())
  accountId           BigInt
  productId           BigInt
  vendorId            BigInt?
  vendorProductId     BigInt?
  purchaseOrderId     BigInt?
  purchaseOrderLineId BigInt?

  locationCode String

  recommendedQty Decimal  @db.Decimal(12, 2)
  finalQty       Decimal? @db.Decimal(12, 2)

  daysUntilStockout    Decimal? @db.Decimal(12, 2)
  reorderPoint         Decimal? @db.Decimal(12, 2)
  targetStock          Decimal? @db.Decimal(12, 2)
  avgDailySales30      Decimal? @db.Decimal(12, 4)
  qtyOnHandSnapshot    Decimal? @db.Decimal(12, 2)
  qtyIncomingSnapshot  Decimal? @db.Decimal(12, 2)
  qtyAvailableSnapshot Decimal? @db.Decimal(12, 2)

  status RecommendationStatus @default(open)

  calculatedAt DateTime  @default(now())
  reviewedAt   DateTime?
  convertedAt  DateTime?
  dismissedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  account           Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor            Vendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorProduct     VendorProduct?     @relation("RecommendationVendorProduct", fields: [vendorProductId], references: [id], onDelete: SetNull)
  purchaseOrder     PurchaseOrder?     @relation("RecommendationPurchaseOrder", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  purchaseOrderLine PurchaseOrderLine? @relation("RecommendationPurchaseOrderLine", fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([accountId, productId, status])
  @@index([accountId, vendorId, status])
  @@index([purchaseOrderId])
}

model PlanningSettings {
  id        Int    @id @default(autoincrement())
  accountId BigInt @unique

  demandOrderStatuses        String[] // e.g. ["FULFILLED", "SHIPPED"]
  demandDateBasis            String   @default("postedAt") // future: createdAt, fulfilledAt, shippedAt
  includeNegativeAdjustments Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
