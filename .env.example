# Copy the appropriate environment template to .env before starting the API:
#   local:      .env.development.example
#   QA/demo:    .env.qa.example
#   production: .env.production.example
#
# Each deployment reads .env from its own working directory. Never commit the
# real environment files because they contain database and application secrets.

NODE_ENV="development"
PORT="3000"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/NVentory Boss"
JWT_SECRET="dev-secret-change-me"

# Email delivery.
# Use "console" locally and "resend" in production.
EMAIL_PROVIDER="console"
EMAIL_FROM="NVentory Boss <no-reply@nventoryboss.com>"
RESEND_API_KEY="replace-with-the-resend-key"

# Password reset links use PASSWORD_RESET_URL_BASE when set.
# Otherwise they default to APP_BASE_URL + "/reset-password".
APP_BASE_URL="http://localhost:5173"
PASSWORD_RESET_URL_BASE="http://localhost:5173/auth/password-reset/request"
CORS_ORIGINS="http://localhost:5173"
