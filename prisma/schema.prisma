// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  active
  inactive
  archived
}

enum OrderStatus {
  pending
  authorized
  paid
  processing
  completed
  cancelled
  refunded
  partially_refunded
  on_hold
}

enum InventoryEventType {
  opening_balance
  sale
  sale_reversal
  receipt
  adjustment
  return_resellable
  sync_correction
  transfer_in
  transfer_out
}

enum ReferenceType {
  order
  receipt
  purchase_order
  adjustment
  return_ref
  transfer
  system
}

enum AdjustmentReasonCodes {
  cycle_count
  damage
  expired
  shrinkage
  opening_balance
  manual_correction
}

enum ReservationStatus {
  active
  released
  consumed
  cancelled
}

enum ReservationSourceType {
  sales_order_line
  sales_order
  manual
}

enum EcommerceProvider {
  woocommerce
  shopify
}

enum EcommerceAuthType {
  none
  basic
  api_key
  oauth
}

enum UserRoleCode {
  executive
  purchasing_manager
  buyer
  planner
  warehouse_manager
  warehouse_user
  system_admin
}

model Account {
  id                      BigInt   @id @default(autoincrement())
  name                    String
  nextPurchaseOrderNumber Int      @default(1000)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                    User[]
  products                 Product[]
  orders                   Order[]
  orderLines               OrderLine[]
  ledger                   InventoryLedger[]
  balances                 InventoryBalance[]
  vendors                  Vendor[]
  vendorPlatforms          VendorPlatform[]
  vendorProducts           VendorProduct[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderLines       PurchaseOrderLine[]
  receipts                 Receipt[]
  receiptLines             ReceiptLine[]
  salesDaily               SalesDaily[]
  inventoryReservations    InventoryReservation[]
  replenishmentRules       ReplenishmentRule[]
  reorderRecommendations   ReorderRecommendation[]
  planningSettings         PlanningSettings?
  locations                Location[]
  userRoles                UserRole[]
  ecommerceConnections     EcommerceConnection[]
  ecommerceProductMappings EcommerceProductMapping[]
  lookupValues             LookupValue[]
  securitySettings         AccountSecuritySettings?
}

model User {
  id                         BigInt    @id @default(autoincrement())
  accountId                  BigInt
  email                      String
  fullName                   String?
  passwordHash               String?
  passwordChangedAt          DateTime?
  passwordResetTokenHash     String?
  passwordResetTokenExpiresAt DateTime?
  passwordResetRequestedAt   DateTime?
  isActive                   Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([accountId, email])
  @@index([passwordResetTokenHash])
}

model Role {
  id          BigInt       @id @default(autoincrement())
  code        UserRoleCode @unique
  displayName String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userRoles UserRole[]
}

model UserRole {
  id        BigInt   @id @default(autoincrement())
  accountId BigInt
  userId    BigInt
  roleId    BigInt
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([accountId, userId, roleId])
  @@index([accountId, roleId])
}

model Product {
  id              BigInt        @id @default(autoincrement())
  accountId       BigInt
  sku             String
  name            String
  status          ProductStatus @default(active)
  isVariant       Boolean       @default(false)
  parentProductId BigInt?
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parentProduct Product?  @relation("ProductParent", fields: [parentProductId], references: [id])
  variants      Product[] @relation("ProductParent")

  orderLines               OrderLine[]
  ledgerEntries            InventoryLedger[]
  balances                 InventoryBalance[]
  vendorProducts           VendorProduct[]
  purchaseOrderLines       PurchaseOrderLine[]
  receiptLines             ReceiptLine[]
  salesDaily               SalesDaily[]
  inventoryReservations    InventoryReservation[]
  replenishmentRule        ReplenishmentRule?
  reorderRecommendations   ReorderRecommendation[]
  ecommerceProductMappings EcommerceProductMapping[]

  @@unique([accountId, sku])
}

model EcommerceConnection {
  id                     BigInt            @id @default(autoincrement())
  accountId              BigInt
  provider               EcommerceProvider
  channelKey             String
  displayName            String
  storeUrl               String?
  externalStoreId        String?
  authType               EcommerceAuthType @default(api_key)
  credentials            Json?
  settings               Json?
  defaultLocationCode    String            @default("MAIN")
  currencyCode           String?
  isActive               Boolean           @default(true)
  lastSyncedAt           DateTime?
  lastConnectionTestedAt DateTime?
  lastConnectionStatus   String?
  lastConnectionError    String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  account         Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  productMappings EcommerceProductMapping[]

  @@unique([accountId, channelKey])
  @@unique([accountId, provider, displayName])
  @@index([accountId, provider])
  @@index([accountId, isActive])
}

model EcommerceProductMapping {
  id                BigInt            @id @default(autoincrement())
  accountId         BigInt
  connectionId      BigInt
  productId         BigInt
  provider          EcommerceProvider
  externalProductId String
  externalVariantId String            @default("")
  externalSku       String?
  externalName      String?
  lastSyncedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  account    Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  connection EcommerceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([accountId, connectionId, externalProductId, externalVariantId])
  @@index([accountId, provider, externalProductId])
  @@index([accountId, connectionId, externalSku])
  @@index([accountId, productId])
}

model Order {
  id             BigInt      @id @default(autoincrement())
  accountId      BigInt
  channel        String
  channelOrderId String
  status         String
  orderedAt      DateTime
  customerName   String?
  customerEmail  String?
  currencyCode   String?
  orderTotal     Decimal?    @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderLines OrderLine[]

  @@unique([accountId, channel, channelOrderId])
}

model LookupValue {
  id                 BigInt   @id @default(autoincrement())
  accountId          BigInt
  lookupType         String
  channelKey         String?
  lookupKeyValue     String
  lookupTextValue    String
  lookupDescription  String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, lookupType, channelKey, lookupKeyValue])
  @@index([accountId, lookupType])
  @@index([accountId, lookupType, channelKey])
}

model OrderLine {
  id            BigInt   @id @default(autoincrement())
  accountId     BigInt
  orderId       BigInt
  productId     BigInt?
  channelLineId String?
  sku           String?
  productName   String?
  quantity      Decimal  @db.Decimal(12, 2)
  unitPrice     Decimal? @db.Decimal(12, 2)
  lineTotal     Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model InventoryLedger {
  id               BigInt             @id @default(autoincrement())
  accountId        BigInt
  productId        BigInt
  locationCode     String
  eventType        InventoryEventType
  quantityDelta    Decimal            @db.Decimal(12, 2)
  unitCost         Decimal?           @db.Decimal(12, 4)
  referenceType    ReferenceType
  referenceId      BigInt?
  externalEventKey String
  occurredAt       DateTime
  notes            String?
  createdAt        DateTime           @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([accountId, externalEventKey])
}

model InventoryBalance {
  accountId        BigInt
  productId        BigInt
  locationCode     String
  qtyOnHand        Decimal  @default(0) @db.Decimal(12, 2)
  qtyReserved      Decimal  @default(0) @db.Decimal(12, 2)
  qtyIncoming      Decimal  @default(0) @db.Decimal(12, 2)
  qtyAvailable     Decimal  @default(0) @db.Decimal(12, 2)
  lastCalculatedAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId, locationCode])
}

enum PurchaseOrderStatus {
  draft
  submitted
  partially_received
  received
  cancelled
}

model Vendor {
  id                  BigInt   @id @default(autoincrement())
  accountId           BigInt
  platformId          BigInt?
  name                String
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  defaultLeadTimeDays Int?
  paymentTerms        String?
  isActive            Boolean  @default(true)
  isPreferred         Boolean  @default(false)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  account                Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform               VendorPlatform?         @relation(fields: [platformId], references: [id], onDelete: SetNull)
  vendorProducts         VendorProduct[]
  purchaseOrders         PurchaseOrder[]
  reorderRecommendations ReorderRecommendation[]

  @@unique([accountId, name])
  @@index([accountId, platformId])
}

model VendorPlatform {
  id             BigInt   @id @default(autoincrement())
  accountId      BigInt
  name           String
  websiteUrl     String?
  loginUrl       String?
  username       String?
  credentials    Json?
  paymentTerms   String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendors Vendor[]

  @@unique([accountId, name])
  @@index([accountId, isActive])
}

model VendorProduct {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  vendorId        BigInt
  productId       BigInt
  vendorSku       String?
  unitCost        Decimal? @db.Decimal(12, 4)
  minOrderQty     Decimal  @default(0) @db.Decimal(12, 2)
  orderMultiple   Decimal  @default(1) @db.Decimal(12, 2)
  leadTimeDays    Int?
  isPrimaryVendor Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendor          Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  recommendations ReorderRecommendation[] @relation("RecommendationVendorProduct")

  purchaseOrderLines PurchaseOrderLine[]

  @@unique([accountId, vendorId, productId])
}

model PurchaseOrder {
  id           BigInt              @id @default(autoincrement())
  accountId    BigInt
  vendorId     BigInt
  poNumber     String
  locationCode String              @default("MAIN")
  status       PurchaseOrderStatus @default(draft)
  orderedAt    DateTime?
  expectedAt   DateTime?
  submittedAt  DateTime?
  cancelledAt  DateTime?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendor          Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines           PurchaseOrderLine[]
  receipts        Receipt[]
  recommendations ReorderRecommendation[] @relation("RecommendationPurchaseOrder")

  @@unique([accountId, poNumber])
}

model PurchaseOrderLine {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  purchaseOrderId BigInt
  productId       BigInt
  vendorProductId BigInt?
  orderedQty      Decimal  @db.Decimal(12, 2)
  receivedQty     Decimal  @default(0) @db.Decimal(12, 2)
  unitCost        Decimal? @db.Decimal(12, 4)
  lineTotal       Decimal? @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  vendorProduct   VendorProduct?          @relation(fields: [vendorProductId], references: [id], onDelete: SetNull)
  recommendations ReorderRecommendation[] @relation("RecommendationPurchaseOrderLine")
  receiptLines    ReceiptLine[]
}

model Receipt {
  id              BigInt   @id @default(autoincrement())
  accountId       BigInt
  purchaseOrderId BigInt
  locationCode    String
  receivedAt      DateTime
  notes           String?
  createdAt       DateTime @default(now())

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  lines         ReceiptLine[]
}

model ReceiptLine {
  id                  BigInt   @id @default(autoincrement())
  accountId           BigInt
  receiptId           BigInt
  purchaseOrderLineId BigInt
  productId           BigInt
  receivedQty         Decimal  @db.Decimal(12, 2)
  unitCost            Decimal? @db.Decimal(12, 4)
  createdAt           DateTime @default(now())

  account           Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  receipt           Receipt           @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
}

enum RecommendationStatus {
  open
  reviewed
  converted
  dismissed
  superseded
}

model SalesDaily {
  accountId BigInt
  productId BigInt
  salesDate DateTime
  unitsSold Decimal  @default(0) @db.Decimal(12, 2)
  revenue   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId, salesDate])
  @@index([accountId, salesDate])
  @@index([accountId, productId, salesDate])
}

model ReplenishmentRule {
  accountId    BigInt
  productId    BigInt @unique
  locationCode String @default("MAIN")

  safetyStock          Decimal @default(0) @db.Decimal(12, 2)
  targetDaysOfCover    Int     @default(30)
  overrideLeadTimeDays Int?
  minReorderQty        Decimal @default(0) @db.Decimal(12, 2)
  isActive             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([accountId, productId])
}

model ReorderRecommendation {
  id                  BigInt  @id @default(autoincrement())
  accountId           BigInt
  productId           BigInt
  vendorId            BigInt?
  vendorProductId     BigInt?
  purchaseOrderId     BigInt?
  purchaseOrderLineId BigInt?

  locationCode String

  recommendedQty Decimal  @db.Decimal(12, 2)
  finalQty       Decimal? @db.Decimal(12, 2)

  daysUntilStockout    Decimal? @db.Decimal(12, 2)
  reorderPoint         Decimal? @db.Decimal(12, 2)
  targetStock          Decimal? @db.Decimal(12, 2)
  avgDailySales30      Decimal? @db.Decimal(12, 4)
  qtyOnHandSnapshot    Decimal? @db.Decimal(12, 2)
  qtyIncomingSnapshot  Decimal? @db.Decimal(12, 2)
  qtyAvailableSnapshot Decimal? @db.Decimal(12, 2)

  status RecommendationStatus @default(open)

  calculatedAt DateTime  @default(now())
  reviewedAt   DateTime?
  convertedAt  DateTime?
  dismissedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  account           Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor            Vendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorProduct     VendorProduct?     @relation("RecommendationVendorProduct", fields: [vendorProductId], references: [id], onDelete: SetNull)
  purchaseOrder     PurchaseOrder?     @relation("RecommendationPurchaseOrder", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  purchaseOrderLine PurchaseOrderLine? @relation("RecommendationPurchaseOrderLine", fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([accountId, productId, status])
  @@index([accountId, vendorId, status])
  @@index([purchaseOrderId])
}

model PlanningSettings {
  id        Int    @id @default(autoincrement())
  accountId BigInt @unique

  demandOrderStatuses        String[] // e.g. ["FULFILLED", "SHIPPED"]
  demandDateBasis            String   @default("orderedAt") // future: createdAt, fulfilledAt, shippedAt, postedAt
  includeNegativeAdjustments Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AccountSecuritySettings {
  id        Int    @id @default(autoincrement())
  accountId BigInt @unique

  passwordMinLength Int @default(12)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Location {
  id        BigInt   @id @default(autoincrement())
  accountId BigInt
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, code])
  @@index([accountId, isActive])
}

model InventoryReservation {
  id           BigInt @id @default(autoincrement())
  accountId    BigInt
  productId    BigInt
  locationCode String

  sourceType ReservationSourceType
  sourceId   BigInt

  reservedQty Decimal           @db.Decimal(12, 2)
  status      ReservationStatus @default(active)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  releasedAt DateTime?
  consumedAt DateTime?
  notes      String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([accountId, productId, locationCode, status])
  @@index([accountId, sourceType, sourceId])
  @@index([accountId, status])
}
